rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserRole(role) {
      return role == 'supplier' || role == 'client';
    }

    function isValidLinkStatus(status) {
      return status == 'pending' ||
        status == 'approved' ||
        status == 'rejected' ||
        status == 'cancelled_by_client' ||
        status == 'revoked_by_supplier';
    }

    function allowedUserFields() {
      return ['displayName', 'createdAt', 'updatedAt', 'role', 'roleSetAt', 'accountRoles'];
    }

    function hasAccountRolesField(data) {
      return data.keys().hasAny(['accountRoles']);
    }

    function accountRolesListIsValid(list) {
      return list is list &&
        list.size() >= 1 &&
        list.size() <= 2 &&
        list[0] is string &&
        isValidUserRole(list[0]) &&
        (
          list.size() == 1 ||
          (
            list[1] is string &&
            isValidUserRole(list[1]) &&
            list[0] != list[1]
          )
        );
    }

    function userAccountRolesShapeValid(data) {
      return !hasAccountRolesField(data) || accountRolesListIsValid(data.accountRoles);
    }

    function userAccountRolesConsistentWithLegacyRole(data) {
      return !hasRoleField(data) ||
        !hasAccountRolesField(data) ||
        (
          data.accountRoles is list &&
          data.accountRoles.hasAll([data.role])
        );
    }

    function requiredUserFields() {
      return ['displayName', 'createdAt', 'updatedAt'];
    }

    function hasRequiredUserFields() {
      return request.resource.data.keys().hasAll(requiredUserFields());
    }

    function hasOnlyAllowedUserFields() {
      return request.resource.data.keys().hasOnly(allowedUserFields());
    }

    function hasRoleField(data) {
      return data.keys().hasAny(['role']);
    }

    function hasRoleSetAtField(data) {
      return data.keys().hasAny(['roleSetAt']);
    }

    function userProfileBaseDataIsValid(data) {
      return data.displayName is string &&
        data.displayName.size() <= 80 &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    function userRoleFieldsAreValid(data) {
      return (
          (!hasRoleField(data) && !hasRoleSetAtField(data)) ||
          (
            hasRoleField(data) &&
            hasRoleSetAtField(data) &&
            data.role is string &&
            isValidUserRole(data.role) &&
            data.roleSetAt is timestamp
          )
        ) &&
        userAccountRolesShapeValid(data) &&
        userAccountRolesConsistentWithLegacyRole(data);
    }

    function userRoleCreateIsValid() {
      return !hasRoleField(request.resource.data) ||
        request.resource.data.roleSetAt == request.time;
    }

    function userProfileUpdateChangesOnlyDisplayAndUpdatedAt() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['displayName', 'updatedAt']);
    }

    function userRoleIsUnset() {
      return !hasRoleField(resource.data) && !hasRoleSetAtField(resource.data);
    }

    function userProfileRoleSetOnce() {
      return userRoleIsUnset() &&
        hasRoleField(request.resource.data) &&
        hasRoleSetAtField(request.resource.data) &&
        request.resource.data.role is string &&
        isValidUserRole(request.resource.data.role) &&
        request.resource.data.roleSetAt == request.time &&
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role', 'roleSetAt', 'updatedAt']) ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['role', 'roleSetAt', 'updatedAt', 'accountRoles']) &&
            accountRolesListIsValid(request.resource.data.accountRoles) &&
            request.resource.data.accountRoles.size() == 1 &&
            request.resource.data.accountRoles[0] == request.resource.data.role
          )
        );
    }

    function userProfileAccountRolesInitialWrite() {
      return resource.data.keys().hasAny(['role']) &&
        resource.data.keys().hasAny(['roleSetAt']) &&
        !resource.data.keys().hasAny(['accountRoles']) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['accountRoles', 'updatedAt']) &&
        request.resource.data.displayName == resource.data.displayName &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.roleSetAt == resource.data.roleSetAt &&
        request.resource.data.updatedAt == request.time &&
        accountRolesListIsValid(request.resource.data.accountRoles) &&
        request.resource.data.accountRoles.hasAll([resource.data.role]);
    }

    function userProfileAccountRolesAddSecond() {
      return resource.data.keys().hasAny(['accountRoles']) &&
        resource.data.accountRoles is list &&
        resource.data.accountRoles.size() == 1 &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['accountRoles', 'updatedAt']) &&
        request.resource.data.displayName == resource.data.displayName &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.roleSetAt == resource.data.roleSetAt &&
        request.resource.data.updatedAt == request.time &&
        accountRolesListIsValid(request.resource.data.accountRoles) &&
        request.resource.data.accountRoles.size() == 2 &&
        request.resource.data.accountRoles.hasAll(resource.data.accountRoles) &&
        userAccountRolesConsistentWithLegacyRole(request.resource.data);
    }

    function allowedLinkFields() {
      return ['supplierId', 'clientId', 'status', 'requestedBy', 'createdAt', 'updatedAt'];
    }

    function linkParticipantsAreValid(data) {
      return data.supplierId is string &&
        data.supplierId.size() > 0 &&
        data.clientId is string &&
        data.clientId.size() > 0 &&
        data.supplierId != data.clientId;
    }

    function isLinkParticipant(data) {
      return isSignedIn() &&
        (request.auth.uid == data.supplierId || request.auth.uid == data.clientId);
    }

    function userHasEffectiveAccountRole(userId, role) {
      let d = get(userDocPath(userId)).data;
      return exists(userDocPath(userId)) && (
        (
          hasAccountRolesField(d) &&
          d.accountRoles is list &&
          accountRolesListIsValid(d.accountRoles) &&
          d.accountRoles.hasAll([role])
        ) ||
        (
          (
            !hasAccountRolesField(d) ||
            !(d.accountRoles is list) ||
            !accountRolesListIsValid(d.accountRoles)
          ) &&
          d.role == role
        )
      );
    }

    function linkDataIsValid(data) {
      return data.keys().hasAll(allowedLinkFields()) &&
        data.keys().hasOnly(allowedLinkFields()) &&
        linkParticipantsAreValid(data) &&
        data.status is string &&
        isValidLinkStatus(data.status) &&
        data.requestedBy is string &&
        data.requestedBy == 'client' &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    function isPendingLinkCreate() {
      return request.auth.uid == request.resource.data.clientId &&
        request.resource.data.status == 'pending' &&
        request.resource.data.requestedBy == 'client' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        userHasEffectiveAccountRole(request.resource.data.clientId, 'client') &&
        userHasEffectiveAccountRole(request.resource.data.supplierId, 'supplier');
    }

    function supplierStatusTransitionIsValid() {
      return request.auth.uid == resource.data.supplierId &&
        (
          request.resource.data.status == 'approved' ||
          request.resource.data.status == 'rejected'
        ) &&
        resource.data.status == 'pending';
    }

    function clientStatusTransitionIsValid() {
      return request.auth.uid == resource.data.clientId &&
        request.resource.data.status == 'cancelled_by_client' &&
        resource.data.status == 'pending';
    }

    function supplierRevocationIsValid() {
      return request.auth.uid == resource.data.supplierId &&
        request.resource.data.status == 'revoked_by_supplier' &&
        resource.data.status == 'approved';
    }

    function linkStatusTransitionIsValid() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.supplierId == resource.data.supplierId &&
        request.resource.data.clientId == resource.data.clientId &&
        request.resource.data.requestedBy == resource.data.requestedBy &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time &&
        (
          supplierStatusTransitionIsValid() ||
          clientStatusTransitionIsValid() ||
          supplierRevocationIsValid()
        );
    }

    // --- loanRequests (pré-financeiro v1; ver docs/LOANREQUEST_V1_CONTRATO_FUNCIONAL_SUBFASE1.md) ---

    function loanRequestLinkPath(linkId) {
      return /databases/$(database)/documents/links/$(linkId);
    }

    function loanRequestTerminalStatus(s) {
      return s == 'approved' || s == 'rejected' || s == 'cancelled_by_client';
    }

    function loanRequestOpenStatus(s) {
      return s == 'pending' || s == 'under_review';
    }

    function loanRequestAmountCentsValid(n) {
      return n is int && n >= 1 && n <= 9999999999;
    }

    function loanRequestNoteValid(note) {
      return note is string && note.size() <= 1000;
    }

    function loanRequestV1ForbiddenKeysCreate(data) {
      return data.keys().hasAny([
        'approvedAmount',
        'respondedAt',
        'cancelledAt',
        'supplierNote',
        'counterofferAmount',
        'readByClientAt',
        'readBySupplierAt'
      ]);
    }

    function loanRequestV1ForbiddenKeysAlways(data) {
      return data.keys().hasAny([
        'counterofferAmount',
        'readByClientAt',
        'readBySupplierAt'
      ]);
    }

    function loanRequestLinkApprovedForLoanRequest(linkId, supplierId, clientId) {
      let link = get(loanRequestLinkPath(linkId));
      return link.exists &&
        link.data.status == 'approved' &&
        link.data.supplierId == supplierId &&
        link.data.clientId == clientId;
    }

    function loanRequestCreateShapeValid() {
      return request.resource.data.keys().hasOnly([
          'supplierId',
          'clientId',
          'linkId',
          'requestedAmount',
          'clientNote',
          'status',
          'createdAt',
          'updatedAt'
        ]) &&
        !loanRequestV1ForbiddenKeysCreate(request.resource.data) &&
        !loanRequestV1ForbiddenKeysAlways(request.resource.data) &&
        request.resource.data.supplierId is string &&
        request.resource.data.supplierId.size() > 0 &&
        request.resource.data.clientId is string &&
        request.resource.data.clientId.size() > 0 &&
        request.resource.data.linkId is string &&
        request.resource.data.linkId.size() > 0 &&
        request.resource.data.supplierId != request.resource.data.clientId &&
        loanRequestAmountCentsValid(request.resource.data.requestedAmount) &&
        loanRequestNoteValid(request.resource.data.clientNote) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function loanRequestCreateAuthorized() {
      return request.auth.uid == request.resource.data.clientId &&
        userHasEffectiveAccountRole(request.resource.data.clientId, 'client') &&
        userHasEffectiveAccountRole(request.resource.data.supplierId, 'supplier') &&
        loanRequestLinkApprovedForLoanRequest(
          request.resource.data.linkId,
          request.resource.data.supplierId,
          request.resource.data.clientId
        );
    }

    function loanRequestParticipantRead() {
      return isSignedIn() &&
        (
          request.auth.uid == resource.data.clientId ||
          request.auth.uid == resource.data.supplierId
        );
    }

    function loanRequestCoreImmutableOnUpdate() {
      return request.resource.data.supplierId == resource.data.supplierId &&
        request.resource.data.clientId == resource.data.clientId &&
        request.resource.data.linkId == resource.data.linkId &&
        request.resource.data.requestedAmount == resource.data.requestedAmount &&
        request.resource.data.clientNote == resource.data.clientNote &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function loanRequestSupplierNoteOkAfter() {
      return !request.resource.data.keys().hasAny(['supplierNote']) ||
        loanRequestNoteValid(request.resource.data.supplierNote);
    }

    function loanRequestAllowedV1Keys(data) {
      return data.keys().hasOnly([
        'supplierId',
        'clientId',
        'linkId',
        'requestedAmount',
        'clientNote',
        'status',
        'createdAt',
        'updatedAt',
        'supplierNote',
        'approvedAmount',
        'respondedAt',
        'cancelledAt'
      ]);
    }

    function loanRequestClientCancelValid() {
      return request.auth.uid == resource.data.clientId &&
        userHasEffectiveAccountRole(resource.data.clientId, 'client') &&
        loanRequestOpenStatus(resource.data.status) &&
        loanRequestLinkApprovedForLoanRequest(
          resource.data.linkId,
          resource.data.supplierId,
          resource.data.clientId
        ) &&
        request.resource.data.status == 'cancelled_by_client' &&
        request.resource.data.cancelledAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt']) &&
        !request.resource.data.keys().hasAny(['approvedAmount', 'respondedAt']) &&
        !loanRequestV1ForbiddenKeysAlways(request.resource.data);
    }

    function loanRequestSupplierToUnderReviewValid() {
      return request.auth.uid == resource.data.supplierId &&
        userHasEffectiveAccountRole(resource.data.supplierId, 'supplier') &&
        resource.data.status == 'pending' &&
        loanRequestLinkApprovedForLoanRequest(
          resource.data.linkId,
          resource.data.supplierId,
          resource.data.clientId
        ) &&
        request.resource.data.status == 'under_review' &&
        request.resource.data.updatedAt == request.time &&
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt', 'supplierNote'])
        ) &&
        loanRequestSupplierNoteOkAfter() &&
        !request.resource.data.keys().hasAny(['approvedAmount', 'respondedAt', 'cancelledAt']) &&
        !loanRequestV1ForbiddenKeysAlways(request.resource.data);
    }

    function loanRequestSupplierApproveDiffOk(keys) {
      return keys.hasOnly(['status', 'updatedAt', 'respondedAt', 'approvedAmount']) ||
        keys.hasOnly(['status', 'updatedAt', 'respondedAt', 'approvedAmount', 'supplierNote']);
    }

    function loanRequestSupplierApproveValid() {
      return request.auth.uid == resource.data.supplierId &&
        userHasEffectiveAccountRole(resource.data.supplierId, 'supplier') &&
        loanRequestOpenStatus(resource.data.status) &&
        loanRequestLinkApprovedForLoanRequest(
          resource.data.linkId,
          resource.data.supplierId,
          resource.data.clientId
        ) &&
        request.resource.data.status == 'approved' &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.respondedAt == request.time &&
        loanRequestAmountCentsValid(request.resource.data.approvedAmount) &&
        request.resource.data.approvedAmount == resource.data.requestedAmount &&
        loanRequestSupplierApproveDiffOk(
          request.resource.data.diff(resource.data).affectedKeys()
        ) &&
        loanRequestSupplierNoteOkAfter() &&
        !request.resource.data.keys().hasAny(['cancelledAt']) &&
        !loanRequestV1ForbiddenKeysAlways(request.resource.data);
    }

    function loanRequestSupplierRejectDiffOk(keys) {
      return keys.hasOnly(['status', 'updatedAt', 'respondedAt']) ||
        keys.hasOnly(['status', 'updatedAt', 'respondedAt', 'supplierNote']);
    }

    function loanRequestSupplierRejectValid() {
      return request.auth.uid == resource.data.supplierId &&
        userHasEffectiveAccountRole(resource.data.supplierId, 'supplier') &&
        loanRequestOpenStatus(resource.data.status) &&
        loanRequestLinkApprovedForLoanRequest(
          resource.data.linkId,
          resource.data.supplierId,
          resource.data.clientId
        ) &&
        request.resource.data.status == 'rejected' &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.respondedAt == request.time &&
        !request.resource.data.keys().hasAny(['approvedAmount']) &&
        loanRequestSupplierRejectDiffOk(
          request.resource.data.diff(resource.data).affectedKeys()
        ) &&
        loanRequestSupplierNoteOkAfter() &&
        !request.resource.data.keys().hasAny(['cancelledAt']) &&
        !loanRequestV1ForbiddenKeysAlways(request.resource.data);
    }

    function loanRequestUpdateValid() {
      return loanRequestAllowedV1Keys(request.resource.data) &&
        !loanRequestV1ForbiddenKeysAlways(request.resource.data) &&
        loanRequestCoreImmutableOnUpdate() &&
        !loanRequestTerminalStatus(resource.data.status) &&
        request.resource.data.keys().hasAll([
          'supplierId',
          'clientId',
          'linkId',
          'requestedAmount',
          'clientNote',
          'status',
          'createdAt',
          'updatedAt'
        ]) &&
        (
          loanRequestClientCancelValid() ||
          loanRequestSupplierToUnderReviewValid() ||
          loanRequestSupplierApproveValid() ||
          loanRequestSupplierRejectValid()
        );
    }

    // Leitura por documento (get) liberada para qualquer usuário autenticado, para
    // validar papel na etapa de vínculo sem Cloud Function. list permanece bloqueado
    // para evitar varredura da coleção.
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isOwner(userId) &&
        hasRequiredUserFields() &&
        hasOnlyAllowedUserFields() &&
        userProfileBaseDataIsValid(request.resource.data) &&
        userRoleFieldsAreValid(request.resource.data) &&
        userRoleCreateIsValid() &&
        !hasAccountRolesField(request.resource.data) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;

      allow update: if isOwner(userId) &&
        hasRequiredUserFields() &&
        hasOnlyAllowedUserFields() &&
        userProfileBaseDataIsValid(request.resource.data) &&
        userRoleFieldsAreValid(request.resource.data) &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time &&
        (
          userProfileUpdateChangesOnlyDisplayAndUpdatedAt() ||
          userProfileRoleSetOnce() ||
          userProfileAccountRolesInitialWrite() ||
          userProfileAccountRolesAddSecond()
        );

      allow delete: if false;
    }

    match /links/{linkId} {
      // `get` em documento ainda inexistente (ex.: transação antes do primeiro `set`)
      // precisa ser permitido: nesse caso o alvo não existe e `resource.data` não aplica.
      allow read: if isSignedIn() &&
        (
          !exists(/databases/$(database)/documents/links/$(linkId)) ||
          isLinkParticipant(resource.data)
        );

      allow create: if isSignedIn() &&
        linkDataIsValid(request.resource.data) &&
        isPendingLinkCreate();

      allow update: if isLinkParticipant(resource.data) &&
        linkDataIsValid(request.resource.data) &&
        linkStatusTransitionIsValid();

      allow delete: if false;
    }

    match /loanRequests/{loanRequestId} {
      allow read: if loanRequestParticipantRead();

      allow create: if isSignedIn() &&
        loanRequestCreateShapeValid() &&
        loanRequestCreateAuthorized() &&
        loanRequestAllowedV1Keys(request.resource.data);

      allow update: if isSignedIn() && loanRequestUpdateValid();

      allow delete: if false;
    }
  }
}
